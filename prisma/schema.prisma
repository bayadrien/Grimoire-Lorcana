generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String       @id
  name        String
  collections Collection[]
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Card {
  id                String   @id
  name              String?
  setName           String?
  setCode           String?
  ink               String?
  rarity            String?
  type              String?
  text              String?
  imageUrl          String?
  updatedAt         DateTime? @updatedAt
  collection_number String?   @map("collection_number")
  name_fr           String?
  usd               Float?
  usd_foil          Float?

  @@map("Card_new")
}

model Collection {
  userId   String
  cardId   String
  quantity Int
  variant  Variant
  card     public_Card @relation(fields: [cardId], references: [id])
  user     User        @relation(fields: [userId], references: [id])

  @@unique([userId, cardId, variant])
  @@index([cardId], map: "idx_collection_cardid")
  @@index([userId, cardId], map: "idx_collection_user_card")
  @@index([userId, cardId, variant], map: "idx_collection_user_card_variant")
  @@index([userId], map: "idx_collection_userid")
}

model Trade {
  id        String      @id @default(cuid())
  fromUser  String
  toUser    String
  cardId    String
  quantity  Int         @default(1)
  createdAt DateTime    @default(now())
  card      public_Card @relation(fields: [cardId], references: [id])

  @@index([fromUser, toUser])
  @@index([cardId])
  @@index([createdAt])
}

model BoosterOpening {
  id           String        @id @default(uuid())
  userId       String
  chapter      Int
  boosterImage String
  totalValue   Float
  createdAt    DateTime      @default(now())
  cards        BoosterCard[]
}

model BoosterCard {
  id        String         @id @default(uuid())
  openingId String
  cardId    String
  foil      Boolean        @default(false)
  card      public_Card    @relation(fields: [cardId], references: [id])
  opening   BoosterOpening @relation(fields: [openingId], references: [id])
}

model public_Card {
  id                String        @id
  name              String
  setName           String
  setCode           String?
  ink               String?
  rarity            String?
  type              String?
  cost              Int?
  strength          Int?
  willpower         Int?
  lore              Int?
  text              String?
  imageUrl          String?
  updatedAt         DateTime
  collection_number String?
  name_fr           String?
  boosterCards      BoosterCard[]
  collections       Collection[]
  trades            Trade[]

  @@map("Card")
}

enum Variant {
  normal
  foil
}
