generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String       @id
  name        String
  collections Collection[]
}

model Card {
  id                String   @id
  name              String
  setName           String
  setCode           String?
  ink               String?
  rarity            String?
  type              String?
  text              String?
  imageUrl          String?
  updatedAt         DateTime @updatedAt
  collection_number String?  @map("collection_number")
  name_fr           String?
  usd               Float?
  usd_foil          Float?

  boosterCards BoosterCard[]
  collections  Collection[]
  trades       Trade[]

  @@map("Card_new")
}

model Collection {
  userId   String
  cardId   String
  quantity Int
  variant  Variant

  user User @relation(fields: [userId], references: [id])
  card Card @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId, variant])

  @@index([userId])
  @@index([cardId])
  @@index([userId, cardId])

}

model Trade {
  id        String   @id @default(cuid())
  fromUser  String
  toUser    String
  cardId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id])

  @@index([fromUser, toUser])
  @@index([cardId])
  @@index([createdAt])
}

model BoosterOpening {
  id           String   @id @default(uuid())
  userId       String
  chapter      Int
  boosterImage String
  totalValue   Float
  createdAt    DateTime @default(now())

  cards BoosterCard[]
}

model BoosterCard {
  id        String  @id @default(uuid())
  openingId String
  cardId    String
  foil      Boolean @default(false)

  card    Card          @relation(fields: [cardId], references: [id])
  opening BoosterOpening @relation(fields: [openingId], references: [id])
}

enum Variant {
  normal
  foil
}
